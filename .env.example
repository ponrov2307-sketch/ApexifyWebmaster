APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080
APP_RELOAD=false
APP_TITLE=Apex Wealth Master
NICEGUI_STORAGE_SECRET=change-to-long-random-secret

# Auth hardening
# shared_passcode = use one secure passcode from admin
# legacy_pin = old method (last 4 digits of Telegram ID)
AUTH_MODE=shared_passcode
AUTH_SHARED_PASSCODE=change-this-passcode
AUTH_MAX_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
AUTH_SESSION_MINUTES=480
AUTH_ALLOW_TOKEN_LOGIN=true
DASHBOARD_LOGIN_SECRET=change-to-strong-shared-secret
DASHBOARD_LOGIN_TOKEN_TTL=300

# Feature flags
FEATURE_PHASE_B_SIGNALS=true
FEATURE_UPSELL_TRACKING=true

# Integrations
TELEGRAM_TOKEN=
ADMIN_ID=
GEMINI_API_KEY=
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=
